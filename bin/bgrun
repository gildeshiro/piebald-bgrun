#!/usr/bin/env bash
# bgrun — fires a long command DETACHED (survives the tool call return in Piebald,
# which runs the terminal SYNCHRONOUSLY). Replicates Claude Code's run_in_background.
# (Name is NOT "bg" on purpose: bg is a bash job-control builtin with PATH precedence.)
#
# Usage:
#   bgrun "<command>"                       # description = the command itself
#   bgrun "<short description>" "<full command>"
#
# Per-job state in ~/.piebald-bg/<job-id>/:
#   cmd desc cwd  -> input
#   out          -> stdout+stderr combined (read later with Read)
#   pid          -> MSYS/Linux pid of the detached runner = process-group leader
#                   (bg-kill signals the whole group: runner + inner bash + command)
#   winpid       -> Windows pid of the runner (belt for "taskkill /T" of native children)
#   start end    -> epoch
#   done         -> written LAST; contains the exit code (completion sentinel)
#   .ack         -> written by the UserPromptSubmit hook upon notification (idempotency)
#
# Completion is notified automatically by the bg-wake hook (UserPromptSubmit):
# do NOT poll synchronously. Check on demand: bg-status / kill: bg-kill.
set -uo pipefail

BG_ROOT="${PIEBALD_BG_ROOT:-$HOME/.piebald-bg}"
mkdir -p "$BG_ROOT"

if [[ $# -eq 1 ]]; then
  DESC="$1"; CMD="$1"
elif [[ $# -ge 2 ]]; then
  DESC="$1"; shift; CMD="$*"
else
  echo "usage: bgrun \"<command>\"  |  bgrun \"<description>\" \"<command>\"" >&2
  exit 2
fi

JOB="$(date +%Y%m%d-%H%M%S)-$(printf '%04x' $((RANDOM)))"
JOBDIR="$BG_ROOT/$JOB"
mkdir -p "$JOBDIR"
CWD="$(pwd)"

printf '%s' "$CMD"  > "$JOBDIR/cmd"
printf '%s' "$DESC" > "$JOBDIR/desc"
printf '%s' "$CWD"  > "$JOBDIR/cwd"

# detached runner: runs in the original CWD, captures everything in out, writes the
# done sentinel last, then ENQUEUES the job id for the wake hook. A trap guarantees a
# sentinel is written even on crash/kill/signal, so the job can NEVER become an orphan
# that the gate counts as "still alive" forever (the bug that froze every prompt).
# (Hard SIGKILL still bypasses the trap — that residue is reaped by bg-clean's
# pid-liveness sweep.)
cat > "$JOBDIR/runner.sh" <<RUNNER
#!/usr/bin/env bash
export PATH="\$HOME/bin:\$HOME/AppData/Roaming/npm:\$HOME/scoop/shims:/usr/bin:/bin:/usr/local/bin:\$PATH"
JOBDIR="$JOBDIR"; BG_ROOT="$BG_ROOT"; JOB="$JOB"
# Finalizer: write the done sentinel + enqueue + raise the gate, exactly once.
finish() {
  local rc="\${1:-143}"
  [[ -f "\$JOBDIR/done" ]] && return 0
  date +%s > "\$JOBDIR/end"
  printf '%s' "\$rc" > "\$JOBDIR/done"
  printf '%s\n' "\$JOB" >> "\$BG_ROOT/.queue"
  : > "\$BG_ROOT/.pending"
}
# On any unexpected exit (crash/kill/TERM) without a recorded rc -> rc 143.
trap 'finish 143' EXIT INT TERM
# Record our OWN pid as the job's process-group leader. When launched detached
# (Windows Start-Process / setsid) this bash is a session/group leader, so \$\$ == pgid
# and bg-kill can reap the whole group (this runner + inner bash + the command).
printf '%s' "\$\$" > "\$JOBDIR/pid"
cd "$CWD" 2>/dev/null || cd "\$HOME"
date +%s > "\$JOBDIR/start"
# Best-effort housekeeping at launch, DETACHED (off the chat path): GC old folders,
# kill stuck jobs, reap dead-pid orphans. Never blocks this runner.
if [[ -x "\$HOME/bin/bg-clean" ]]; then
  if command -v setsid >/dev/null 2>&1; then setsid "\$HOME/bin/bg-clean" --quiet >/dev/null 2>&1 &
  else nohup "\$HOME/bin/bg-clean" --quiet >/dev/null 2>&1 & fi
  disown 2>/dev/null || true
fi
bash -lc "\$(cat '$JOBDIR/cmd')" > "\$JOBDIR/out" 2>&1
rc=\$?
trap - EXIT INT TERM
finish "\$rc"
RUNNER
chmod +x "$JOBDIR/runner.sh"

# NOTE: .pending is raised at COMPLETION (by the runner's finish()), not at launch.
# While a job is still running there is nothing to announce, so the gate stays closed
# and the wake hook costs ~5ms per prompt during long jobs (the .cmd gate exits before
# even spawning bash). The hook fires only once a job actually finishes.

# real detach: Windows -> PowerShell Start-Process (independent process that
# survives the tool call return); elsewhere -> setsid/nohup.
if command -v powershell.exe >/dev/null 2>&1; then
  BASHEXE="$(cygpath -w "$(command -v bash)")"
  # -PassThru returns the launched process; record its WINDOWS pid as a belt so
  # bg-kill can also "taskkill /T" any NATIVE child subtree. (The cygwin group
  # leader pid is written by runner.sh into the pid file — used for the group kill.)
  PID_OUT="$(powershell.exe -NoProfile -Command "(Start-Process -WindowStyle Hidden -FilePath '$BASHEXE' -ArgumentList '$JOBDIR/runner.sh' -PassThru).Id" 2>/dev/null | tr -d '\r\n ')"
  [[ -n "$PID_OUT" ]] && printf '%s' "$PID_OUT" > "$JOBDIR/winpid"
elif command -v setsid >/dev/null 2>&1; then
  # setsid -> new session/process-group leader (runner.sh's \$\$ == pgid), so bg-kill
  # can signal the whole group with "kill -TERM -<pid>".
  setsid bash "$JOBDIR/runner.sh" >/dev/null 2>&1 &
else
  nohup bash "$JOBDIR/runner.sh" >/dev/null 2>&1 &
  disown 2>/dev/null || true
fi

echo "[bgrun] job $JOB launched (detached). desc: $DESC"
echo "[bgrun] output -> $JOBDIR/out"
echo "[bgrun] the UserPromptSubmit hook will notify on completion. check now: bg-status $JOB"
