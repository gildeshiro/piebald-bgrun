#!/usr/bin/env bash
# bgrun — dispara um comando longo DESTACADO (sobrevive ao retorno do tool call no
# Piebald, que roda o terminal SÍNCRONO). Replica o run_in_background do Claude Code.
# (Nome NÃO é "bg" de propósito: bg é builtin de job control do bash e tem precedência.)
#
# Uso:
#   bgrun "<comando>"                       # descrição = o próprio comando
#   bgrun "<descrição curta>" "<comando completo>"
#
# Estado por job em ~/.piebald-bg/<job-id>/:
#   cmd desc cwd  -> entrada
#   out          -> stdout+stderr combinados (lido depois com Read)
#   start end    -> epoch
#   done         -> escrito ao FIM, contém o exit code (sentinela de conclusão)
#   .ack         -> escrito pelo hook UserPromptSubmit ao notificar (idempotência)
#
# Conclusão é notificada automaticamente pelo hook bg-wake (UserPromptSubmit):
# NÃO faça poll síncrono. Checar sob demanda: bg-status / matar: bg-kill.
set -uo pipefail

BG_ROOT="${PIEBALD_BG_ROOT:-$HOME/.piebald-bg}"
mkdir -p "$BG_ROOT"

if [[ $# -eq 1 ]]; then
  DESC="$1"; CMD="$1"
elif [[ $# -ge 2 ]]; then
  DESC="$1"; shift; CMD="$*"
else
  echo "uso: bgrun \"<comando>\"  |  bgrun \"<descrição>\" \"<comando>\"" >&2
  exit 2
fi

JOB="$(date +%Y%m%d-%H%M%S)-$(printf '%04x' $((RANDOM)))"
JOBDIR="$BG_ROOT/$JOB"
mkdir -p "$JOBDIR"
CWD="$(pwd)"

printf '%s' "$CMD"  > "$JOBDIR/cmd"
printf '%s' "$DESC" > "$JOBDIR/desc"
printf '%s' "$CWD"  > "$JOBDIR/cwd"

# runner destacado: roda no CWD original, captura tudo em out, escreve a sentinela
# done(rc) por último. Reexporta PATH porque processo destacado pode não herdar tudo.
cat > "$JOBDIR/runner.sh" <<RUNNER
#!/usr/bin/env bash
export PATH="\$HOME/bin:\$HOME/AppData/Roaming/npm:\$HOME/scoop/shims:/usr/bin:/bin:/usr/local/bin:\$PATH"
cd "$CWD" 2>/dev/null || cd "\$HOME"
date +%s > "$JOBDIR/start"
bash -lc "\$(cat '$JOBDIR/cmd')" > "$JOBDIR/out" 2>&1
rc=\$?
date +%s > "$JOBDIR/end"
printf '%s' "\$rc" > "$JOBDIR/done"
touch "$BG_ROOT/.pending"
RUNNER
chmod +x "$JOBDIR/runner.sh"

# marcador de gate barato pro hook .cmd (só spawna bash se .pending existir)
touch "$BG_ROOT/.pending"

# detach real: Windows -> PowerShell Start-Process (processo independente que
# sobrevive ao retorno do tool call); fora do Windows -> setsid/nohup.
if command -v powershell.exe >/dev/null 2>&1; then
  BASHEXE="$(cygpath -w "$(command -v bash)")"
  powershell.exe -NoProfile -Command "Start-Process -WindowStyle Hidden -FilePath '$BASHEXE' -ArgumentList '$JOBDIR/runner.sh'" >/dev/null 2>&1 || true
elif command -v setsid >/dev/null 2>&1; then
  setsid bash "$JOBDIR/runner.sh" >/dev/null 2>&1 &
else
  nohup bash "$JOBDIR/runner.sh" >/dev/null 2>&1 &
  disown 2>/dev/null || true
fi

echo "[bgrun] job $JOB lançado (destacado). desc: $DESC"
echo "[bgrun] output -> $JOBDIR/out"
echo "[bgrun] o hook UserPromptSubmit avisa ao terminar. checar agora: bg-status $JOB"
