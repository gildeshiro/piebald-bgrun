#!/usr/bin/env bash
# bg-kill <job-id> — kills the detached runner of a job by cmdline (targeted,
# never broad). Marks the job as terminated (rc=143) so the hook closes the sentinel.
set -uo pipefail
BG_ROOT="${PIEBALD_BG_ROOT:-$HOME/.piebald-bg}"
job="${1:?usage: bg-kill <job-id>}"
JOBDIR="$BG_ROOT/$job"
[[ -d "$JOBDIR" ]] || { echo "job not found: $job" >&2; exit 1; }
if command -v powershell.exe >/dev/null 2>&1; then
  # kill only processes whose cmdline references this job's id (job's runner.sh)
  powershell.exe -NoProfile -Command "Get-CimInstance Win32_Process | Where-Object { \$_.CommandLine -match [regex]::Escape('$job') } | ForEach-Object { Stop-Process -Id \$_.ProcessId -Force -ErrorAction SilentlyContinue }" >/dev/null 2>&1 || true
else
  pkill -f "$job" 2>/dev/null || true
fi
[[ -f "$JOBDIR/done" ]] || printf '%s' "143" > "$JOBDIR/done"
touch "$BG_ROOT/.pending"
echo "[bg-kill] $job signaled (terminated)."
exit 0
